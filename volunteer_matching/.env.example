# AI Volunteer Matching System — local environment example
# Copy this file to .env and fill values as needed.
# Never commit the real .env file.

# Optional Groq API key for AI explanations/summaries.
# Leave empty to safely disable Groq features.
GROQ_API_KEY=

# Optional SQLite override. Leave empty to use data/volunteer_matching.db.
DB_PATH=

# Optional application/session secret for future token/cookie flows.
APP_SECRET=change_me_to_a_long_random_string

# Optional future email notification placeholders. Email is disabled by default.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Optional Windows OCR path. Required only if Tesseract is installed but not on PATH.
# Example: TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
