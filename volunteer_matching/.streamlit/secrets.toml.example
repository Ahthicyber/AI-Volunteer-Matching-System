# Copy this file to .streamlit/secrets.toml for local Streamlit secrets.
# On Streamlit Community Cloud, add these values in App settings → Secrets.

GROQ_API_KEY = "your_groq_api_key_here"

# Optional future SMTP/email support. Disabled unless implemented/configured.
SMTP_HOST = ""
SMTP_PORT = ""
SMTP_USER = ""
SMTP_PASSWORD = ""

# Optional Windows/local OCR executable path; usually not needed on Streamlit Cloud when packages.txt is used.
TESSERACT_CMD = ""
